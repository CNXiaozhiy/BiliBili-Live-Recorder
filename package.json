{
  "name": "bilibili-live-recorder",
  "version": "1.0.0",
  "description": "A Node.js-based Bilibili live streaming recording system, supporting multi-language interfaces and quick subscription features, developed with TypeScript.",
  "author": "Xz",
  "bin": "dist/app.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CNXiaozhiy/BiliBili-Live-Recorder.git"
  },
  "scripts": {
    "build": "webpack --mode production",
    "package": "pkg . --out-path=build -t win",
    "dev": "ts-node src/app.ts"
  },
  "pkg": {
    "assets": ["node_modules/**/*.js"],
    "scripts": "dist/**/*.js"
  },
  "dependencies": {
    "axios": "0.27.0",
    "axios-retry": "^4.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "i18next": "^24.2.2",
    "moment": "^2.30.1",
    "request": "^2.88.2",
    "sqlite3": "^5.1.7",
    "throttled-queue": "^2.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.8",
    "@babel/plugin-transform-modules-commonjs": "^7.26.3",
    "@babel/preset-env": "^7.26.8",
    "@babel/preset-typescript": "^7.26.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.1",
    "@types/request": "^2.48.12",
    "@types/ws": "^8.5.14",
    "babel-loader": "^9.2.1",
    "eslint": "^7.23.0",
    "ts-loader": "^9.5.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
